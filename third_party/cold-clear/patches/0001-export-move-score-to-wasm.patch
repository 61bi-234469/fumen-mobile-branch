+
+impl BotState<crate::evaluation::Standard> {
+    pub fn suggest_move_with_score(
+        &mut self,
+        eval: &crate::evaluation::Standard,
+        book: Option<&Book>,
+        incoming: u32,
+    ) -> Option<(Move, crate::Info, f64)> {
+        if !self.min_thinking_reached() {
+            return None;
+        }
+
+        let candidates = self.tree.get_next_candidates();
+        if candidates.is_empty() {
+            return None;
+        }
+        let mut book_move = None;
+        if let Some(book) = book {
+            if self.tree.board().column_heights().iter().all(|&h| h <= 10) {
+                book_move = book.suggest_move(self.tree.board());
+            }
+        }
+        let mut picked = None;
+        if let Some(book_move) = book_move {
+            for mv in &candidates {
+                if mv.mv.same_location(&book_move) {
+                    picked = Some(mv.clone());
+                    break;
+                }
+            }
+        }
+        if picked.is_none() && book_move.is_some() {
+            dbg!("book picked a move we can't do?");
+        }
+        let child = picked.unwrap_or_else(|| eval.pick_move(candidates, incoming));
+
+        let plan = if book_move.is_none() {
+            self.tree.get_plan()
+        } else {
+            vec![]
+        };
+
+        let info = if book_move.is_some() {
+            crate::Info::Book
+        } else {
+            crate::Info::Normal(Info {
+                nodes: if book_move.is_some() {
+                    0
+                } else {
+                    self.tree.nodes()
+                },
+                depth: if book_move.is_some() {
+                    6
+                } else {
+                    self.tree.depth() as u32
+                },
+                original_rank: child.original_rank,
+                plan,
+            })
+        };
+
+        let score = child.evaluation.score();
+        let mv = self.to_move(&child)?;
+        Some((mv, info, score))
+    }
+
+    pub fn suggest_top_moves_with_score(&self, count: usize) -> Vec<(Move, f64)> {
+        if count == 0 || !self.min_thinking_reached() {
+            return vec![];
+        }
+
+        self.tree
+            .get_next_candidates()
+            .into_iter()
+            .take(count)
+            .filter_map(|candidate| {
+                self.to_move(&candidate)
+                    .map(|mv| (mv, candidate.evaluation.score()))
+            })
+            .collect()
+    }
 }
 
